NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Authentication (Supabase):
# Dashboard → Authentication → Providers → Email: enable it.
# URL configuration: add redirect URL `${NEXT_PUBLIC_SITE_URL}/auth/callback`
# Site URL should match NEXT_PUBLIC_SITE_URL (prod use your deployed origin).
# -----------------------------------------------------------------------------
# AI (OpenAI-compatible chat). Default provider is OpenAI.
# Set `AI_PROVIDER` to switch: `openai` | `groq` | `custom`
# -----------------------------------------------------------------------------
AI_PROVIDER=openai

# --- When AI_PROVIDER=openai (default) ---
OPENAI_API_KEY=
# Optional overrides:
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# --- When AI_PROVIDER=groq ---
# GROQ_API_KEY=
# Optional:
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_MODEL=llama-3.3-70b-versatile

# --- When AI_PROVIDER=custom (LiteLLM, Azure OpenAI-compatible proxy, etc.) ---
# LLM_API_KEY=
# LLM_BASE_URL=https://your-host/v1
# LLM_MODEL=your-model-id

# YouTube Data API v3 (Shorts tab). Create a key in Google Cloud Console and enable “YouTube Data API v3”.
YOUTUBE_API_KEY=
